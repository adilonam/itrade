// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?        @map("email_verified")
  image           String?
  password        String? // For credentials provider
  balance         Float            @default(0) @map("balance")
  role            Role             @default(USER)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  leverage        Int              @default(1) @map("leverage")
  // Theme preferences
  themeMode       String?          @default("system") @map("theme_mode") // "light", "dark", "system"
  themeColor      String?          @default("default") @map("theme_color") // "default", "blue", "green", etc.
  reducedMotion   Boolean          @default(false) @map("reduced_motion")
  highContrast    Boolean          @default(false) @map("high_contrast")
  accounts        Account[]
  sessions        Session[]
  mfaChallenges   MfaChallenge[]
  positions       Position[]
  userInvestments UserInvestment[]
  transactions    Transaction[]

  @@map("users")
}

model MfaChallenge {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  code      String
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_challenges")
}

enum MarketType {
  FOREX
  CRYPTO
  STOCKS
  COMMODITIES
  INDICES
}

enum Room {
  STOCK
  TRADING
}

model Market {
  id                String     @id @default(cuid())
  type              MarketType
  symbol            String
  name              String
  room              Room       @default(TRADING)
  spread            Float      @default(0)
  lastPrice         Float      @default(0)
  lastChange        Float      @default(0)
  lastPercentChange Float      @default(0)
  lastPreviousClose Float      @default(0)
  visible           Boolean    @default(true)
  image             String?    @db.Text // Base64 encoded image data
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  positions         Position[]

  @@map("markets")
}

enum PositionType {
  BUY
  SELL
}

enum PositionStatus {
  PLACED
  CLOSED
  FAILED
  PENDING
  SPLITTED
}

model Position {
  id     String         @id @default(cuid())
  userId String         @map("user_id")
  type   PositionType
  status PositionStatus @default(PENDING)
  room   Room           @default(TRADING)

  // Market/Asset information
  marketId String @map("market_id")

  // Position amounts
  quantity Float // Quantity of assets (for buy/sell positions in lots)

  // Price information
  executedPrice Float? @map("executed_price") // Price when position was executed
  closedPrice   Float? @map("closed_price") // Price when position was closed

  // Risk management
  takeProfit     Float? @map("take_profit") // Take profit price level
  stopLoss       Float? @map("stop_loss") // Stop loss price level
  requiredMargin Float? @map("required_margin") // Required margin for the position

  // Reference and metadata
  description String? // Position description

  // Timestamps
  executedAt DateTime? @map("executed_at") // When position was executed
  closedAt   DateTime? @map("closed_at") // When position was closed

  // PnL
  pnl Float? @map("pnl") // on complete position

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: SetNull)

  // Indexes for better query performance

  @@map("positions")
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Investment {
  id               String  @id @default(cuid())
  title            String
  description      String? @db.Text
  country          String
  duration         Int // Duration in months
  rentability      Float // Annual rentability percentage
  minInvestment    Float   @map("min_investment")
  maxInvestment    Float?  @map("max_investment")
  autoReinvestment Boolean @default(false) @map("auto_reinvestment")
  totalCapacity    Float?  @map("total_capacity") // Maximum total investment allowed
  currentCapacity  Float   @default(0) @map("current_capacity") // Current invested amount
  riskLevel        String  @default("MEDIUM") @map("risk_level") // LOW, MEDIUM, HIGH
  isActive         Boolean @default(true) @map("is_active")
  imageUrl         String? @map("image_url")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userInvestments UserInvestment[]

  @@map("investments")
}

model UserInvestment {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  investmentId String           @map("investment_id")
  amount       Float
  status       InvestmentStatus @default(ACTIVE)

  // Investment details
  startDate      DateTime @default(now()) @map("start_date")
  endDate        DateTime @map("end_date")
  expectedReturn Float    @map("expected_return") // Calculated expected return
  actualReturn   Float?   @map("actual_return") // Actual return when completed

  // Auto-reinvestment settings
  autoReinvest Boolean @default(false) @map("auto_reinvest")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@map("user_investments")
}

// Transaction model for tracking user financial transactions
model Transaction {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  type        TransactionType
  absoluteAmount      Float  @default(0) // absolute amount of the transaction
  description String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// Transaction type enum
enum TransactionType {
  GAIN // Profit from trading or investment or stock market
  LOSS // Loss from trading or investment or stock market
  DEPOSIT // Money deposited to account
  WITHDRAW // Money withdrawn from account
}

// App Settings model for global configuration
model AppSettings {
  id            String   @id @default("default")
  appIcon       String?  @map("app_icon") // Path to uploaded icon
  appName       String   @default("Trading Dashboard") @map("app_name")
  // Global theme settings
  themeMode     String   @default("system") @map("theme_mode") // "light", "dark", "system"
  themeColor    String   @default("green") @map("theme_color") // "default", "blue", "green", etc.
  reducedMotion Boolean  @default(false) @map("reduced_motion")
  highContrast  Boolean  @default(false) @map("high_contrast")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

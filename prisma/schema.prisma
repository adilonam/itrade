// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SELLER
  ADMIN
  SUPERADMIN
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum KycVerificationRequestStatus {
  PENDING
  IN_PROGRESS
  VERIFIED
  REJECTED
}

enum KycDocumentKind {
  FRONT
  BACK
  SELFIE
  UTILITY_BILL
}

// Demo-friendly multi-account balances for a single user.
enum BalanceType {
  REAL
  DEMO
  INSTITUTIONAL
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String                   @unique
  emailVerified           DateTime?                @map("email_verified")
  image                   String? // profile image URL (e.g. Vercel Blob URL)
  password                String? // For credentials provider
  role                    Role                     @default(USER)
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  leverage                Int                      @default(1000) @map("leverage")
  // Theme preferences
  themeMode               String?                  @default("system") @map("theme_mode") // "light", "dark", "system"
  themeColor              String?                  @default("default") @map("theme_color") // "default", "blue", "green", etc.
  reducedMotion           Boolean                  @default(false) @map("reduced_motion")
  highContrast            Boolean                  @default(false) @map("high_contrast")
  phone                   String?                  @map("phone")
  dateOfBirth             DateTime?                @map("date_of_birth")
  address                 String?                  @map("address")
  postalCode              String?                  @map("postal_code")
  city                    String?                  @map("city")
  country                 String?                  @map("country")
  gender                  String?                  @map("gender")
  kycStatus               KycStatus                @default(NOT_SUBMITTED) @map("kyc_status")
  kycDocumentType         String?                  @map("kyc_document_type")
  kycFrontImageUrl        String?                  @map("kyc_front_image_url") @db.Text
  kycBackImageUrl         String?                  @map("kyc_back_image_url") @db.Text
  kycSelfieUrl            String?                  @map("kyc_selfie_url") @db.Text
  kycUtilityBillUrl       String?                  @map("kyc_utility_bill_url") @db.Text
  accounts                Account[]
  sessions                Session[]
  mfaChallenges           MfaChallenge[]
  passwordResetTokens     PasswordResetToken[]
  positions               Position[]
  userInvestments         UserInvestment[]
  withdrawRequests        WithdrawRequest[]
  seller                  User?                    @relation("SellerUsers", fields: [sellerId], references: [id], onDelete: SetNull)
  sellerId                String?                  @map("seller_id")
  sellerUsers             User[]                   @relation("SellerUsers")
  sentMessages            Message[]                @relation("MessageSender")
  receivedMessages        Message[]                @relation("MessageReceiver")
  botUsers                BotUser[]
  balances                UserBalance[]
  kycVerificationRequests KycVerificationRequest[] @relation("KycUserRequests")
  reviewedKycRequests     KycVerificationRequest[] @relation("KycReviewedBy")

  @@map("users")
}

model KycVerificationRequest {
  id           String                       @id @default(cuid())
  userId       String                       @map("user_id")
  documentType String                       @map("document_type")
  status       KycVerificationRequestStatus @default(PENDING) @map("status")
  notes        String?                      @map("notes") @db.Text
  createdAt    DateTime                     @default(now()) @map("created_at")
  updatedAt    DateTime                     @updatedAt @map("updated_at")
  reviewedAt   DateTime?                    @map("reviewed_at")
  reviewedById String?                      @map("reviewed_by_id")

  user       User                      @relation("KycUserRequests", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?                     @relation("KycReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  documents  KycVerificationDocument[]

  @@index([userId])
  @@index([status])
  @@map("kyc_verification_requests")
}

model KycVerificationDocument {
  id        String          @id @default(cuid())
  requestId String          @map("request_id")
  kind      KycDocumentKind @map("kind")
  fileUrl   String          @map("file_url") @db.Text
  createdAt DateTime        @default(now()) @map("created_at")

  request KycVerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("kyc_verification_documents")
}

model UserBalance {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  type      BalanceType
  amount    Float       @default(0) @map("amount")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions             Transaction[]
  depositRequests          DepositRequest[]
  transferRequestsSent     TransferRequest[] @relation("TransferSenderBalance")
  transferRequestsReceived TransferRequest[] @relation("TransferRecipientBalance")

  @@unique([userId, type])
  @@map("user_balances")
}

model MfaChallenge {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  code      String
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_challenges")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

enum MarketType {
  FOREX
  CRYPTO
  STOCKS
  COMMODITIES
  INDICES
}

enum Room {
  STOCK
  TRADING
  INSTITUTIONAL
}

model Market {
  id                String     @id @default(cuid())
  type              MarketType
  symbol            String
  name              String
  room              Room       @default(TRADING)
  spread            Float      @default(0)
  lastPrice         Float      @default(0)
  lastChange        Float      @default(0)
  lastPercentChange Float      @default(0)
  lastPreviousClose Float      @default(0)
  visible           Boolean    @default(true)
  image             String?    @db.Text // Base64 encoded image data
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  positions         Position[]
  botUsers          BotUser[]

  @@map("markets")
}

enum PositionType {
  BUY
  SELL
}

enum PositionStatus {
  PLACED
  CLOSED
  FAILED
  PENDING
  SPLITTED
}

model Position {
  id     String         @id @default(cuid())
  userId String         @map("user_id")
  type   PositionType
  status PositionStatus @default(PENDING)
  room   Room           @default(TRADING)

  // Market/Asset information
  marketId String @map("market_id")

  // Position amounts
  quantity Float // Quantity of assets (for buy/sell positions in lots)

  // Price information
  executedPrice Float? @map("executed_price") // Price when position was executed
  closedPrice   Float? @map("closed_price") // Price when position was closed

  // Risk management
  takeProfit     Float? @map("take_profit") // Take profit price level
  stopLoss       Float? @map("stop_loss") // Stop loss price level
  requiredMargin Float? @map("required_margin") // Required margin for the position

  // Reference and metadata
  description String? // Position description
  bot         Bot?    @map("bot") // Bot that created the position, if any

  // Timestamps
  executedAt DateTime? @map("executed_at") // When position was executed
  closedAt   DateTime? @map("closed_at") // When position was closed

  // PnL
  pnl Float? @map("pnl") // on complete position

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: SetNull)

  // Indexes for better query performance

  @@map("positions")
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Investment {
  id               String  @id @default(cuid())
  title            String
  description      String? @db.Text
  duration         Int // Duration in calendar days
  rentability      Float // Annual rentability percentage
  minInvestment    Float   @map("min_investment")
  maxInvestment    Float?  @map("max_investment")
  autoReinvestment Boolean @default(false) @map("auto_reinvestment")
  totalCapacity    Float?  @map("total_capacity") // Maximum total investment allowed
  currentCapacity  Float   @default(0) @map("current_capacity") // Current invested amount
  riskLevel        String  @default("MEDIUM") @map("risk_level") // LOW, MEDIUM, HIGH
  isActive         Boolean @default(true) @map("is_active")
  imageUrl         String? @map("image_url")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userInvestments UserInvestment[]

  @@map("investments")
}

model UserInvestment {
  id           String           @id @default(cuid())
  userId       String           @map("user_id")
  investmentId String           @map("investment_id")
  amount       Float
  status       InvestmentStatus @default(ACTIVE)

  // Investment details
  startDate      DateTime @default(now()) @map("start_date")
  endDate        DateTime @map("end_date")
  expectedReturn Float    @map("expected_return") // Calculated expected return
  actualReturn   Float?   @map("actual_return") // Actual return when completed

  // Auto-reinvestment settings
  autoReinvest Boolean @default(false) @map("auto_reinvest")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@map("user_investments")
}

// Transaction model for tracking user financial transactions
model Transaction {
  id             String          @id @default(cuid())
  userBalanceId  String          @map("user_balance_id")
  type           TransactionType
  absoluteAmount Float           @default(0) // absolute amount of the transaction
  description    String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userBalance UserBalance @relation(fields: [userBalanceId], references: [id], onDelete: Cascade)

  @@index([userBalanceId])
  @@map("transactions")
}

// Transaction type enum
enum TransactionType {
  GAIN // Profit from trading or investment or stock market
  INVESTMENT_GAIN // Payout when a user investment matures (principal + expected return)
  LOSS // Loss from trading or investment or stock market
  DEPOSIT // Money deposited to account
  WITHDRAW // Money withdrawn from account
  TRANSFER_IN // Inbound internal transfer (e.g. REAL ↔ INSTITUTIONAL)
  TRANSFER_OUT // Outbound internal transfer (e.g. REAL ↔ INSTITUTIONAL)
}

// App Settings model for global configuration
model AppSettings {
  id         String  @id @default("default")
  appIcon    String? @map("app_icon") // Path to uploaded icon
  appName    String  @default("Trade Nova") @map("app_name")
  // When true, users can create/update/close positions; when false, only admin/superadmin can
  openMarket Boolean @default(true) @map("open_market")

  googleClientId     String? @map("google_client_id")
  googleClientSecret String? @map("google_client_secret") @db.Text

  twelveDataApiKeyPublic String? @map("twelve_data_api_key_public") @db.Text
  twelveDataApiKey       String? @map("twelve_data_api_key") @db.Text

  smtpHost      String? @map("smtp_host")
  smtpPort      String  @default("587") @map("smtp_port")
  smtpSecure    Boolean @default(false) @map("smtp_secure")
  smtpUser      String? @map("smtp_user")
  smtpPassword  String? @map("smtp_password") @db.Text
  smtpFromEmail String? @map("smtp_from_email")

  minMarginLevel Int @default(100) @map("min_margin_level")

  alphaVantageApiKey String? @map("alpha_vantage_api_key") @db.Text

  nowpaymentsApiKey    String? @map("nowpayments_api_key") @db.Text
  nowpaymentsIpnSecret String? @map("nowpayments_ipn_secret") @db.Text

  manualUsdtDepositWalletAddress String? @map("manual_usdt_deposit_wallet_address") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// Message model for user-to-user messaging
model Message {
  id         String   @id @default(cuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  message    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([read])
  @@map("messages")
}

// Useful links shown to users (e.g. in Liens Utiles)
model UsefulLink {
  id        String   @id @default(cuid())
  title     String   @map("title")
  url       String   @map("url") @db.Text
  order     Int      @default(0) @map("order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("useful_links")
}

enum WithdrawMethod {
  PAYPAL
  BANK_TRANSFER
}

enum WithdrawRequestStatus {
  PENDING
  REJECTED
  PROCESSING
  APPROVED
}

enum TransferRequestStatus {
  PENDING
  REJECTED
  PROCESSING
  APPROVED
}

enum DepositRequestStatus {
  PENDING
  WAITING
  CONFIRMING
  FINISHED
  FAILED
  EXPIRED
  REFUNDED
}

enum DepositRequestChannel {
  GATEWAY // NOWPayments invoice flow
  MANUAL // User sends USDT to configured wallet; admin confirms
}

model WithdrawRequest {
  id         String                @id @default(cuid())
  userId     String                @map("user_id")
  amount     Float                 @map("amount")
  method     WithdrawMethod        @map("method")
  status     WithdrawRequestStatus @default(PENDING) @map("status")
  details    Json?                 @map("details") // paypal: { email }, bank: { accountHolderName, bankName, accountNumber, routingNumber }
  adminNotes String?               @map("admin_notes") @db.Text
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("withdraw_requests")
}

model TransferRequest {
  id                     String                @id @default(cuid())
  senderUserBalanceId    String                @map("sender_user_balance_id")
  recipientUserBalanceId String                @map("recipient_user_balance_id")
  amount                 Float                 @map("amount")
  status                 TransferRequestStatus @default(PENDING) @map("status")
  adminNotes             String?               @map("admin_notes") @db.Text
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  senderUserBalance    UserBalance @relation("TransferSenderBalance", fields: [senderUserBalanceId], references: [id], onDelete: Cascade)
  recipientUserBalance UserBalance @relation("TransferRecipientBalance", fields: [recipientUserBalanceId], references: [id], onDelete: Cascade)

  @@index([senderUserBalanceId])
  @@index([recipientUserBalanceId])
  @@index([status])
  @@map("transfer_requests")
}

model DepositRequest {
  id                String                @id @default(cuid())
  userBalanceId     String                @map("user_balance_id")
  amountUsd         Float                 @map("amount_usd")
  payCurrency       String                @map("pay_currency")
  channel           DepositRequestChannel @default(GATEWAY) @map("channel")
  status            DepositRequestStatus  @default(PENDING) @map("status")
  nowPaymentId      String?               @unique @map("now_payment_id")
  nowPaymentStatus  String?               @map("now_payment_status")
  checkoutUrl       String?               @map("checkout_url") @db.Text
  orderId           String                @unique @map("order_id")
  creditedAt        DateTime?             @map("credited_at")
  lastWebhookAt     DateTime?             @map("last_webhook_at")
  rawWebhookPayload Json?                 @map("raw_webhook_payload")
  adminNotes        String?               @map("admin_notes") @db.Text
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  userBalance UserBalance @relation(fields: [userBalanceId], references: [id], onDelete: Cascade)

  @@index([userBalanceId])
  @@index([status])
  @@index([channel])
  @@map("deposit_requests")
}

enum Bot {
  RSI
  GRID_TRADING
  TREND_FOLLOWING
}

model BotUser {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  bot         Bot
  dateStart   DateTime @map("date_start")
  dateStop    DateTime @map("date_stop")
  quantityLot Float    @map("quantity_lot")
  marketId    String   @map("market_id")
  interval    String   @default("1h") @map("interval") // 1min, 5min, 15min, 30min, 45min, 1h, 2h, 4h, 5h, 1day, 1week, 1month
  botParams   Json     @map("bot_params")
  active      Boolean  @default(true) @map("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([marketId])
  @@map("bot_users")
}

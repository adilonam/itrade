# =================================================================
# App Configuration
# =================================================================
NEXT_PUBLIC_APP_NAME="Trade Nova"

# =================================================================
# Database Configuration
# =================================================================
# PostgreSQL database connection string
# For Docker setup: postgresql://trading_user:trading_password@localhost:5432/trading_app_db
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# =================================================================
# Authentication Configuration (NextAuth.js)
# =================================================================
# NextAuth.js configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =================================================================
# Twelve Data API Configuration
# =================================================================
# Twelve Data API configuration for comprehensive market data
# Get your API key from: https://twelvedata.com/
# Free plan includes 800 requests per day
# Use "demo" for testing with limited data

NEXT_PUBLIC_TWELVE_DATA_API_KEY="your-twelvedata-api-key"
TWELVE_DATA_API_KEY="your-twelvedata-api-key"


# =================================================================
# SMTP (Email for MFA/Notifications) from Resend
# =================================================================
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM_EMAIL="noreply@example.com"


# =================================================================
# Trading Configuration
# =================================================================
# Minimum margin level percentage before triggering margin call (default: 100)
# If a user's margin level falls below this value, all their positions will be automatically closed
MIN_MARGIN_LEVEL=100


# =================================================================
# Alpha Vantage API Configuration
# =================================================================
# For news sentiment API
ALPHAVANTAGE_API_KEY="your-alphavantage-api-key"


# =================================================================
# Vercel Blob (profile image uploads)
# =================================================================
# Create a token at: Vercel Dashboard > Storage > Blob > Create Token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# =================================================================
# NOWPayments Configuration (Crypto deposits)
# =================================================================
# API key from https://nowpayments.io/
NOWPAYMENTS_API_KEY="your-nowpayments-api-key"
# IPN secret used to verify webhook signatures
NOWPAYMENTS_IPN_SECRET="your-nowpayments-ipn-secret"